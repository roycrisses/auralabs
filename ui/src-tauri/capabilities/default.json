{
  "$schema": "https://raw.githubusercontent.com/nickel-org/nickel/master/src/schema.json",
  "identifier": "default",
  "description": "Default capabilities for Agent Aura",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "shell:allow-execute",
    "shell:allow-spawn",
    "shell:allow-kill",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister"
  ]
}
