{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentAura",
  "version": "0.1.0",
  "identifier": "com.aura.orchestrator",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Agent Aura",
        "width": 1000,
        "height": 700,
        "minWidth": 700,
        "minHeight": 500,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/aura-server"
    ],
    "resources": [
      "bin/aura-server.exe"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      }
    }
  },
  "plugins": {
    "shell": {
      "sidecar": [
        {
          "name": "bin/aura-server",
          "command": "aura-server",
          "sidecar": true
        }
      ]
    }
  }
}